{
  "name": "@nextclaw/desktop",
  "version": "0.0.21",
  "private": true,
  "description": "NextClaw desktop shell powered by Electron.",
  "author": "NextClaw Team",
  "main": "dist/main.js",
  "license": "MIT",
  "scripts": {
    "icons:generate": "node scripts/generate-icons.mjs",
    "dev": "node scripts/ensure-runtime.mjs && pnpm build:main && env -u ELECTRON_RUN_AS_NODE electron .",
    "build": "pnpm build:main",
    "build:main": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json --outDir dist --noEmit false",
    "lint": "eslint \"src/**/*.ts\"",
    "tsc": "tsc -p tsconfig.json --noEmit",
    "pack": "node scripts/ensure-runtime.mjs && pnpm build:main && electron-builder --dir",
    "dist": "node scripts/ensure-runtime.mjs && pnpm build:main && electron-builder",
    "smoke": "pnpm build:main && node scripts/smoke-runtime.mjs"
  },
  "dependencies": {
    "@nextclaw/channel-plugin-dingtalk": "workspace:*",
    "@nextclaw/channel-plugin-discord": "workspace:*",
    "@nextclaw/channel-plugin-email": "workspace:*",
    "@nextclaw/channel-plugin-feishu": "workspace:*",
    "@nextclaw/channel-plugin-mochat": "workspace:*",
    "@nextclaw/channel-plugin-qq": "workspace:*",
    "@nextclaw/channel-plugin-slack": "workspace:*",
    "@nextclaw/channel-plugin-telegram": "workspace:*",
    "@nextclaw/channel-plugin-wecom": "workspace:*",
    "@nextclaw/channel-plugin-whatsapp": "workspace:*",
    "@nextclaw/channel-runtime": "workspace:*",
    "@nextclaw/core": "workspace:*",
    "@nextclaw/openclaw-compat": "workspace:*",
    "@nextclaw/server": "workspace:*",
    "electron-updater": "^6.6.2",
    "nextclaw": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "electron": "^32.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "io.nextclaw.desktop",
    "productName": "NextClaw Desktop",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "asar": false,
    "mac": {
      "icon": "build/icons/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Peiiii",
        "repo": "nextclaw"
      }
    ]
  }
}
