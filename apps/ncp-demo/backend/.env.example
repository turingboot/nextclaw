# Auto mode: if OPENAI_API_KEY + base_url/OPENAI_BASE_URL are set, backend uses real OpenAI-compatible API.
# Otherwise it falls back to mock LLM.
NCP_DEMO_LLM_MODE=auto

# Support both keys; OPENAI_BASE_URL has higher priority when both are present.
base_url=https://code.pumpkinai.vip/v1
# OPENAI_BASE_URL=https://code.pumpkinai.vip/v1

OPENAI_MODEL=gpt-5.3-codex
OPENAI_API_KEY=YOUR_API_KEY_HERE

# Reasoning/thinking (pick one based on your provider):
# - OpenAI-style (o1, o3, gpt-5): NCP_DEMO_REASONING_EFFORT=low|medium|high|none
# - DashScope/Qwen (qwen-plus, qwen3-*): NCP_DEMO_ENABLE_THINKING=true|false
# Note: qwen3-coder-next may not support thinking; try qwen-plus or qwen3-235b-a22b-thinking.
# NCP_DEMO_REASONING_EFFORT=medium
# NCP_DEMO_ENABLE_THINKING=true

# File store directory for demo session/run persistence.
# Defaults to ".ncp-demo-store" under current working directory.
# NCP_DEMO_STORE_DIR=/absolute/path/to/ncp-demo-store
