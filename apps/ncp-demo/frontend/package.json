{
  "name": "@nextclaw/ncp-demo-frontend",
  "version": "0.0.8",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 127.0.0.1 --port 5181 --strictPort",
    "build": "vite build --config vite.config.ts --outDir dist",
    "lint": "cd ../../.. && pnpm exec eslint apps/ncp-demo/frontend --config apps/ncp-demo/frontend/eslint.config.mjs",
    "tsc": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@nextclaw/ncp": "workspace:*",
