{
  "name": "@nextclaw/channel-plugin-feishu",
  "version": "0.2.14",
  "private": false,
  "description": "NextClaw Feishu/Lark channel plugin with doc/wiki/drive tools.",
  "type": "module",
  "exports": {
    ".": {
      "default": "./index.ts"
    }
  },
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "skills",
    "src"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "feishu",
      "label": "Feishu",
      "selectionLabel": "Feishu/Lark (飞书)",
      "docsPath": "/channels/feishu",
      "docsLabel": "feishu",
      "blurb": "飞书/Lark enterprise messaging with doc/wiki/drive tools.",
      "aliases": [
        "lark"
      ],
      "order": 35,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@nextclaw/channel-plugin-feishu",
      "localPath": "packages/extensions/nextclaw-channel-plugin-feishu",
      "defaultChoice": "npm"
    }
  },
  "scripts": {
    "lint": "eslint index.ts",
    "prepublishOnly": "node ../../../scripts/ensure-pnpm-publish.mjs"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@sinclair/typebox": "0.34.48",
    "https-proxy-agent": "^8.0.0",
    "openclaw": "2026.3.13",
    "zod": "^4.3.6"
  }
}
