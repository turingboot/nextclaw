{
  "name": "@nextclaw/nextclaw-engine-codex-sdk",
  "version": "0.3.3",
  "private": false,
  "description": "NextClaw Codex engine plugin backed by OpenAI Codex SDK.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "prepublishOnly": "node ../../../scripts/ensure-pnpm-publish.mjs"
  },
  "files": [
    "dist",
    "codex-sdk-loader.cjs",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "dist/index.js"
    ]
  },
  "dependencies": {
    "@nextclaw/core": "^0.10.0",
    "@openai/codex-sdk": "^0.107.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
