{
  "name": "@nextclaw/feishu-core",
  "version": "0.2.0",
  "private": false,
  "description": "Feishu platform core for NextClaw.",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "node ../../../scripts/ensure-pnpm-publish.mjs"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.58.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "prettier": "^3.3.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
