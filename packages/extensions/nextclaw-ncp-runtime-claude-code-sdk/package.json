{
  "name": "@nextclaw/nextclaw-ncp-runtime-claude-code-sdk",
  "version": "0.1.6",
  "private": false,
  "description": "Optional NCP runtime adapter backed by Anthropic Claude Agent SDK.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "prepublishOnly": "node ../../../scripts/ensure-pnpm-publish.mjs"
  },
  "files": [
    "dist",
    "claude-code-loader.cjs",
    "README.md"
  ],
  "dependencies": {
    "@nextclaw/ncp": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.2.63"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
