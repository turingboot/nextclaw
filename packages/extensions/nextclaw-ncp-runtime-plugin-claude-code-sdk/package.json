{
  "name": "@nextclaw/nextclaw-ncp-runtime-plugin-claude-code-sdk",
  "version": "0.1.15",
  "private": false,
  "description": "NextClaw plugin that registers Claude Agent SDK as an optional NCP runtime.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "prepublishOnly": "node ../../../scripts/ensure-pnpm-publish.mjs"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "dist/index.js"
    ]
  },
  "dependencies": {
    "@nextclaw/core": "workspace:*",
    "@nextclaw/ncp": "workspace:*",
    "@nextclaw/ncp-toolkit": "workspace:*",
    "@nextclaw/nextclaw-ncp-runtime-claude-code-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
